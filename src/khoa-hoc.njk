---
layout: base.njk
title: "Khóa học"
description: "Các chương trình học STEM dành cho trẻ từ 5 đến 11+ tuổi tại STEM TOWN."
permalink: /khoa-hoc/
---
<section class="page-hero page-hero--compact">
  <div class="wrap">
    <p class="eyebrow eyebrow--light">CHƯƠNG TRÌNH HỌC</p>
    <h1>Khóa học tại STEM TOWN</h1>
  </div>
</section>

<section class="section">
  <div class="wrap">
    <div class="course-list">
      {% for c in collections.courses %}
      <article class="course-detail-card" id="{{ c.slug }}">
        <img src="{{ c.image }}" alt="{{ c.age_group }}" loading="lazy">
        <div class="course-detail-card__body">
          <h2>{{ c.age_group }}</h2>
          <p>{{ c.summary }}</p>
          <ul class="checklist">
            {% for m in c.modules %}
            <li>{{ m }}</li>
            {% endfor %}
          </ul>
          <a class="btn btn--primary" href="/lien-he/">Đăng ký tư vấn</a>
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
